{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      }
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "mcp-server-notion"],
      "env": {
        "NOTION_API_KEY": ""
      }
    },
    "gmail": {
      "command": "npx",
      "args": ["-y", "mcp-server-gmail"],
      "env": {}
    },
    "calendar": {
      "command": "npx",
      "args": ["-y", "mcp-server-google-calendar"],
      "env": {}
    }
  }
}
